# --- Supabase ---
# Create a project at https://supabase.com/dashboard → Project Settings → API Keys
# Uses the new Supabase key format (sb_publishable_* / sb_secret_*)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Server-only. Bypasses RLS. Never expose to the browser.
SUPABASE_SECRET_KEY=sb_secret_xxxxx

# --- Anthropic (Claude) ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- SendGrid (email) ---
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxx
# Must be a verified sender identity in SendGrid
SENDGRID_FROM_EMAIL=hello@yourdomain.com
# Optional: reusable dynamic template IDs
# SENDGRID_TEMPLATE_WELCOME=d-xxxx
# SENDGRID_TEMPLATE_ASSESSMENT_RESULT=d-xxxx

# --- Operator allow-list (Phase 1) ---
# Comma-separated list of emails allowed to sign in
ALLOWED_OPERATOR_EMAILS=you@yourdomain.com

# --- Environment marker ---
# dev | staging | prod — used to gate seed scripts so prod never gets mock data.
APP_ENV=dev

# --- Stripe (Phase 9 — leave blank for now) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
